# ─────────────────────────────────────────────────────────────────────────────
# AccessBridge AI — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real keys.

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
#
# SERVER-ONLY key — used by /api/generate (Vercel serverless function).
# This key MUST NOT have the VITE_ prefix. It will never appear in the
# browser bundle. Get a key at https://aistudio.google.com/
#
GEMINI_API_KEY=your_gemini_api_key_here

# ── Local Development Mode ────────────────────────────────────────────────────
#
# Set to "true" to skip all API calls and use pre-written mock responses.
# Recommended for local development — no API key needed.
# Set to "false" (or remove) in Vercel production environment.
#
VITE_USE_MOCK_AI=true

# ── App URL (optional) ────────────────────────────────────────────────────────
#
# Only needed if you build features that construct absolute URLs.
# In Vercel this is set automatically via VERCEL_URL.
#
# VITE_APP_URL=http://localhost:5173
